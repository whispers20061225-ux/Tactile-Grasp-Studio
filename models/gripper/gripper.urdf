<?xml version="1.0"?>
<robot name="simple_gripper">
  <link name="gripper_base">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.04 0.02"/>
      </geometry>
      <material name="gripper_gray">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.04 0.02"/>
      </geometry>
    </collision>
  </link>

  <link name="left_finger">
    <inertial>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.06"/>
      </geometry>
      <material name="finger_blue">
        <color rgba="0.3 0.3 0.9 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.06"/>
      </geometry>
    </collision>
  </link>

  <joint name="left_finger_joint" type="fixed">
    <parent link="gripper_base"/>
    <child link="left_finger"/>
    <origin xyz="0 0.025 0" rpy="0 0 0"/>
  </joint>

  <link name="right_finger">
    <inertial>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.06"/>
      </geometry>
      <material name="finger_blue">
        <color rgba="0.3 0.3 0.9 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.06"/>
      </geometry>
    </collision>
  </link>

  <joint name="right_finger_joint" type="fixed">
    <parent link="gripper_base"/>
    <child link="right_finger"/>
    <origin xyz="0 -0.025 0" rpy="0 0 0"/>
  </joint>
</robot>
