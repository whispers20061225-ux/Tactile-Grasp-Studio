      "position_kd": 0.05,
      "velocity_kp": 0.5,
      "velocity_ki": 0.01,
      "velocity_kd": 0.02,
      "current_kp": 0.3,
      "current_ki": 0.01,
      "current_kd": 0.001,
      "feedforward_velocity": 0.0,
      "feedforward_acceleration": 0.0,
      "deadband": 1.0,
      "smooth_factor": 0.1,
      "backlash_compensation": 0.0
